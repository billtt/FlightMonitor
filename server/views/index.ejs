<!doctype html>

<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <title>Flight Monitor</title>
    <meta name="author" content="billtt">

    <meta property="og:title" content="Flight Monitor">
    <meta property="og:type" content="website">

    <meta name="viewport" content="initial-scale=1.0, user-scalable=no" />

    <link href="css/bootstrap.min.css" rel="stylesheet">
    <link href="css/bootstrap4-toggle.min.css" rel="stylesheet">

    <style type="text/css">
        html {
            height: 100%;
        }

        body {
            height: 100%;
            margin: 0;
            paddng: 0;
        }

        sup {
            font-weight: bold;
            color: gray;
        }

        .subtle {
            font-size: 80%;
            color: #343a40;
        }

        .title {
            margin-top: 15px;
            font-size: 0.9em;
            font-weight: bold;
            background-color: #f0f0f0;
            padding: 5px 0px;
        }

        #map {
            height: 100%;
        }

        #uiOverlay {
            display: contents;
        }

        #status {
            width: 248px;
            padding: 0;
            position: absolute;
            z-index: 1;
            left: 10px;
            top: 10px;
        }

        #metar {
            width: 520px;
            max-width: calc(100% - 20px);
            padding: 0;
            position: absolute;
            z-index: 1;
            right: 10px;
            top: 10px;
        }

        #status .col {
            padding: 0;
        }

        #status .card, #metar .card {
            background: rgba(255, 255, 255, 0.94);
        }

        #status .card-header {
            padding: 8px 4px !important;
        }

        #status .card-body {
            padding: 12px;
        }

        #metar .card-header {
            padding: 8px 10px !important;
        }

        #metarOrigin,#metarDest {
            text-align: left;
            overflow: hidden;
            flex: 1;
            min-width: 0;
            margin: 0 !important;
        }

        #valIcao, #valFlightCat {
            font-weight: bold;
        }

        #valMetarTime {
            font-size: 0.8em;
        }

        .hidden {
            visibility: hidden;
        }

        .descent-ref {
            background: #efefef;
            margin-top: 8px;
            padding: 5px 0;
            font-size: 0.88rem;
        }

        .indicator {
            border-left: 3px solid;
            padding: 0.6em !important;
        }

        .button-box {
            display: inline-block;
            font-size: 0.68rem;
            width: 72px;
        }

        .noDisplay {
            display: none;
        }

        .LIFR { border-left-color: magenta; }
        .IFR { border-left-color: red; }
        .MVFR { border-left-color: blue; }
        .VFR { border-left-color: green; }
        .estimatedWeather { border-left-color: #f39c12; }

        .airport-title {
            display: flex;
            align-items: baseline;
            justify-content: space-between;
        }

        .airport-code {
            font-size: 1.05rem;
            font-weight: 700;
            letter-spacing: 0.06em;
        }

        .airport-meta, .weather-source {
            color: #6c757d;
            font-size: 0.62rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        .weather-raw {
            display: block;
            margin-top: 5px;
            font-family: monospace;
            font-size: 0.68rem;
            line-height: 1.25;
        }

        .airport-cards {
            display: flex;
            gap: 6px;
        }

        .runway-inline {
            margin-top: 5px;
            padding-top: 5px;
            border-top: 1px solid #e2e6ea;
            font-size: 0.78rem;
            font-weight: 700;
        }

        .runway-source-label {
            margin-right: 3px;
            color: #7b838a;
            font-size: 0.56rem;
            font-weight: 700;
            letter-spacing: 0.07em;
            vertical-align: 0.08rem;
        }

        .runway-separator {
            margin: 0 6px;
            color: #adb5bd;
            font-weight: 400;
        }

        .plane-local-time {
            margin-top: 5px;
            color: #6c757d;
            font-size: 0.62rem;
            font-weight: 600;
            letter-spacing: 0.05em;
        }

        .flight-distance {
            font-size: 1rem;
        }

        .flight-speed {
            font-size: 1rem;
        }

        @media (max-width: 800px) {
            #status { width: 220px; }
            #metar { width: 470px; }
            .button-box { width: 64px; }
        }

        @media (orientation: portrait) and (max-width: 600px) {
            #uiOverlay {
                display: contents;
            }

            #status {
                top: 6px;
                left: 6px;
                width: min(320px, calc(100% - 12px));
                padding: 0;
            }

            #status .card {
                margin-bottom: 0 !important;
            }

            #metar {
                top: auto;
                right: auto;
                bottom: 6px;
                left: 6px;
                width: min(320px, calc(100% - 12px));
                max-width: none;
                max-height: 48vh;
                padding: 0;
                overflow-y: auto;
                scrollbar-width: none;
            }

            #metar::-webkit-scrollbar {
                display: none;
            }

            .airport-cards { flex-direction: column; }
            #metarOrigin, #metarDest { width: 100%; }
            .weather-raw { font-size: 0.62rem; }
        }

    </style>

    <script src="js/jquery-3.6.0.min.js"></script>
    <script src="js/moment.js"></script>
    <script src="js/bootstrap.min.js"></script>
    <script src="js/bootstrap4-toggle.min.js"></script>
    <script src="js/gcj-transform.js"></script>

</head>

<body>

<div id="map"></div>

<div id="uiOverlay">

<div class="container" id="status">
    <main>
        <div class="row row-cols-1 row-cols-md-1 mb-3 text-center">
            <div class="col">
                <div class="card mb-4 rounded-3 shadow-sm">
                    <div class="card-header py-3 indicator" id="spdIndicator">
                        <div class="button-box">
                            Plan<br/><button type="button" class="btn btn-primary btn-sm" id="btPlan">Load</button>
                        </div>
                        <div class="button-box">
                            Follow<br/><input type="checkbox" checked data-toggle="toggle" data-size="sm" id="chkAutoCenter"/>
                        </div>
                        <div class="button-box">
                            Zoom<br/><input type="checkbox" checked data-toggle="toggle" data-size="sm" id="chkAutoZoom"/>
                        </div>
                        <div class="plane-local-time">POSITION · <span id="valPlaneTime">—</span></div>
                    </div>
                    <div class="card-body">
                        <div class="progress">
                            <div class="progress-bar progress-bar-striped progress-bar-animated" role="progressbar" aria-valuenow="75" aria-valuemin="0" aria-valuemax="100" style="width: 0%" id="pgbPercent"></div>
                        </div>
                        <span class="flight-distance">
                            <b><span id="valDistance">0.0</span> <sup>nm</sup></b>
                            + <span style="font-size:80%;"><span id="valRemainingDist">0.0</span> <sup>nm</sup></span>
                            <button type="button" class="btn btn-light btn-sm" id="btFixDistance" style="margin-bottom: 5px;">...</button>
                        </span>
                        <ul class="list-unstyled mt-3 mb-4" style="margin: 0px 0px !important;">
                            <li class="flight-speed">
                                <b><span id="valGS">0.0</span> <sup>kts</sup></b>
                                <b><span id="valAltitude">0.0</span> <sup>ft</sup></b>
                            </li>
                            <li class="descent-ref noDisplay" id="descentRef">
                                <span style="color:gray;">ToD</span>
                                <span id="valTodDistance" style="font-weight:bold;">0.0</span> <sup>nm</sup> |
                                <span id="valTodEte">0<sup>h</sup>0<sup>min</sup></span>
                                <br/>
                                <span id="valDesAngle">0.0</span>°
                                <span id="valDesVelocity">0.0</span><sup>ft/min</sup>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>

        </div>
    </main>
</div>

<div class="container noDisplay" id="metar">
    <main class="airport-cards">
                <div class="card mb-4 rounded-3 shadow-sm" id="metarOrigin">
                    <div class="card-header py-3 indicator" id="fcatIndicatorOrigin">
                        <div class="airport-title">
                            <span class="airport-code" id="valIcaoOrigin">ZBAA</span>
                            <span class="airport-meta"><span id="valElevationOrigin">0</span> FT · <span id="valLocalTimeOrigin">—</span></span>
                        </div>
                        <div class="weather-source"><span id="valWeatherSourceOrigin">WEATHER</span> · <span id="valMetarTimeOrigin">-</span></div>
                        <span class="weather-raw" id="valMetarOrigin"></span>
                        <div class="runway-inline noDisplay" id="runwayInfoOrigin">
                            <span id="planRunwayOrigin"><span class="runway-source-label">PLAN</span><span id="valPlanRunwayOrigin"></span></span>
                            <span class="noDisplay" id="atisRunwayOrigin"><span class="runway-separator">·</span><span class="runway-source-label">ATIS</span><span id="valAtisRunwayOrigin"></span></span>
                        </div>
                    </div>
                </div>
                <div class="card mb-4 rounded-3 shadow-sm" id="metarDest">
                    <div class="card-header py-3 indicator" id="fcatIndicatorDest">
                        <div class="airport-title">
                            <span class="airport-code" id="valIcaoDest">ZBAA</span>
                            <span class="airport-meta"><span id="valElevationDest">0</span> FT · <span id="valLocalTimeDest">—</span></span>
                        </div>
                        <div class="weather-source"><span id="valWeatherSourceDest">WEATHER</span> · <span id="valMetarTimeDest">-</span></div>
                        <span class="weather-raw" id="valMetarDest"></span>
                        <div class="runway-inline noDisplay" id="runwayInfoDest">
                            <span id="planRunwayDest"><span class="runway-source-label">PLAN</span><span id="valPlanRunwayDest"></span></span>
                            <span class="noDisplay" id="atisRunwayDest"><span class="runway-separator">·</span><span class="runway-source-label">ATIS</span><span id="valAtisRunwayDest"></span></span>
                        </div>
                    </div>
                </div>
    </main>
</div>

</div>

</body>

<script src="js/Utils.js?v=1"></script>
<script src="js/FlightMonitor.js?v=6"></script>
<script type="text/javascript">
    _debug = <%=debug%>;
</script>
<script src="js/MapConvertor.js?v=1"></script>
